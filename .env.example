# 1. LIVEKIT CLOUD / LOCAL INFRASTRUCTURE
LIVEKIT_URL="wss://your-project.livekit.cloud"
LIVEKIT_API_KEY="your_api_key_here"
LIVEKIT_API_SECRET="your_api_secret_here"
LIVEKIT_SIP_TRUNK_ID="your_sip_trunk_id"
LIVEKIT_RECORDING_URL=""  # Base URL for recording downloads (optional)

# 2. AI PROVIDER API KEYS (PRIMARY)
OPENAI_API_KEY="sk-..."                       # Primary LLM (gpt-4o-mini)
DEEPGRAM_API_KEY="your_deepgram_key"          # Primary STT (nova-3)
SARVAM_API_KEY="your_sarvam_key"              # Primary TTS (bulbul:v3)

# 3. AI PROVIDER API KEYS (FALLBACKS)
GROQ_API_KEY="gsk_..."                        # Fallback LLM (llama-3.1-70b-versatile)
AZURE_SPEECH_KEY="your_azure_speech_key"      # Fallback STT & TTS
AZURE_SPEECH_REGION="centralindia"            # Azure Region

# 4. SIP TRUNK (TWILIO)
SIP_DID_NUMBER="1206939400"
SIP_PROVIDER_DOMAIN="sip.provider.com"
SIP_PORT="5060"
SIP_USERNAME="your_sip_username"
SIP_PASSWORD="your_sip_password"

# 5. WEBHOOKS & INTEGRATIONS
WEBHOOK_URL=""                                # POST call dispositions here
SMS_WEBHOOK_URL=""                            # SMS fallback endpoint (e.g., Twilio SMS)
WHATSAPP_API_URL=""                           # WhatsApp Business API endpoint
WHATSAPP_API_TOKEN=""                         # WhatsApp API token

# 6. API SECURITY
API_AUTH_TOKEN=""                             # Bearer token for backend API auth

# 7. RATE LIMITING
RATE_LIMIT_WINDOW=60                          # Window in seconds
RATE_LIMIT_MAX=30                             # Max requests per window

# 8. MODEL CONFIGURATIONS
PRIMARY_LLM_MODEL="gpt-4o-mini"
PRIMARY_STT_MODEL="nova-3"
PRIMARY_STT_LANGUAGE="multi"
PRIMARY_TTS_MODEL="bulbul:v3"
PRIMARY_TTS_SPEAKER="priya"
PRIMARY_TTS_LANGUAGE="en-IN"

FALLBACK_LLM_MODEL="llama-3.1-70b-versatile"
FALLBACK_TTS_VOICE="en-IN-NeerjaNeural"

# 9. LATENCY TUNING
MIN_ENDPOINTING_DELAY=0.4
MAX_ENDPOINTING_DELAY=0.8
MIN_INTERRUPTION_DURATION=0.3
TTS_PACE=1.2
TTS_MIN_BUFFER=30
TTS_MAX_CHUNK=50

# 10. POSTGRESQL (optional — for Phase 4 production scaling)
# DATABASE_URL="postgresql+asyncpg://user:pass@localhost:5432/renewal_bot"

# 11. CELERY (optional — for async campaign processing)
# CELERY_BROKER_URL="redis://localhost:6379/0"
