LIVEKIT_URL="wss://your-project.livekit.cloud"
LIVEKIT_API_KEY="your_livekit_api_key"
LIVEKIT_API_SECRET="your_livekit_api_secret"
LIVEKIT_SIP_TRUNK_ID="your_sip_trunk_id"         # Created in LiveKit Cloud SIP section
LIVEKIT_RECORDING_URL=""                          # Optional: base URL for recording downloads

OPENAI_API_KEY="sk-..."
PRIMARY_LLM_MODEL="gpt-4o-mini"                   # Default, can use gpt-4o etc.
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.3

DEEPGRAM_API_KEY="your_deepgram_api_key"
PRIMARY_STT_MODEL="nova-3"                        # Default STT model
PRIMARY_STT_LANGUAGE="multi"                      # "multi" for Hindi/English/Hinglish

TTS_PROVIDER="sarvam"                             # Primary TTS (legacy, overrides TTS_FALLBACK if set)
TTS_FALLBACK="sarvam,elevenlabs,deepgram"         # Comma-separated fallback order

SARVAM_API_KEY="sk_..."
PRIMARY_TTS_MODEL="bulbul:v3"
PRIMARY_TTS_SPEAKER="priya"                       # Speakers: priya, male, etc.
PRIMARY_TTS_LANGUAGE="en-IN"                      # auto-detect or region code
TTS_PACE=1.2                                      # Speaking speed
TTS_MIN_BUFFER=30                                 # Min audio buffer (ms)
TTS_MAX_CHUNK=50                                  # Max chunk length (ms)

ELEVENLABS_API_KEY="sk_..."
ELEVENLABS_VOICE_ID="21m00Tcm4TlvDq8ikWAM"       # Voice ID from elevenlabs.io
ELEVENLABS_MODEL="eleven_turbo_v2_5"              # Default turbo model

DEEPGRAM_TTS_MODEL="aura-2-andromeda-en"          # Deepgram Aura voice model

SIP_DID_NUMBER="your_did_number"                  # e.g. 1206939400
SIP_PROVIDER_DOMAIN="sip.provider.com"            # e.g. 10.100.98.3
SIP_PORT="5060"                                   # SIP port (default 5060)
SIP_USERNAME="your_sip_username"                  # SIP auth username
SIP_PASSWORD="your_sip_password"                  # SIP auth password

WEBHOOK_URL=""                                    # POST call dispositions here on end
SMS_WEBHOOK_URL=""                                # SMS fallback endpoint
WHATSAPP_API_URL=""                               # WhatsApp Business API endpoint
WHATSAPP_API_TOKEN=""                             # WhatsApp API token

API_AUTH_TOKEN=""                                 # Bearer token for API auth
RATE_LIMIT_WINDOW=60                              # Rate limit window (seconds)
RATE_LIMIT_MAX=30                                 # Max requests per window

MIN_ENDPOINTING_DELAY=0.4                         # Silence before response (min, sec)
MAX_ENDPOINTING_DELAY=0.8                         # Silence before response (max, sec)
MIN_INTERRUPTION_DURATION=0.3                     # Min speech duration to interrupt (sec)

# DATABASE_URL="postgresql+asyncpg://user:pass@localhost:5432/renewal_bot"
